{
  "project": "CATCHA BUGS",
  "repository": "HESEB/catchabugs",
  "engineBaseline": "9.0-unified-core",
  "previousBaseline": "8.0-runtime-cleanup",
  "baselineCommit": "ac4e51a29b2973f0d2a53c748e406c9eea6f2eb2",
  "manifestUpdatedAt": "2026-07-08",
  "purpose": "Unify Engine 1.0 through 8.0 into one owner-based runtime standard without reloading old patch layers.",
  "runtimeRule": {
    "readThisFirst": true,
    "updateFromLatestMainOnly": true,
    "doNotRestoreOldPatchFiles": true,
    "oneFeatureOneOwner": true,
    "noDuplicateDomOwners": true,
    "preserveCurrentIndexScriptList": true,
    "mergeOldFeaturesIntoOwnersOnly": true
  },
  "engine9Principles": [
    "Engine 9.0 is not another patch layer. It is the new project baseline.",
    "Old features are included as migration candidates, not directly reloaded.",
    "Every future feature must have one runtime owner.",
    "index.html must never be replaced from an older snapshot.",
    "Disabled runtime files are not deleted yet, but they must not be loaded without explicit migration."
  ],
  "featureCoverageFromEngine1To8": {
    "engine1_initialExplorationCapture": ["src/main-radar.js", "src/data/bugs.js", "src/insect-ai.js"],
    "engine2_saveQuestAchievement": ["src/save-system.js", "src/quest.js", "src/achievement.js", "src/save-reset-guard.js"],
    "engine3_menuModal": ["src/menu-remaster.js", "src/main-radar.js"],
    "engine4_bugHoleReturn": ["src/bug-hole-system.js", "src/bug-hole-markers.js", "src/return-discovery.js", "src/return-stones.js"],
    "engine5_patchAccumulation": ["disabled: src/engine-5-4-0-stability.js", "active: src/radar-compass-system.js"],
    "engine6_runtimeCleanup": ["index.html runtime list", "docs/engine-8-0-runtime-cleanup.md"],
    "engine6_1_gps": ["src/gps-system.js"],
    "engine6_2_explorerDex": ["src/radar-compass-system.js", "migration candidate: src/dex-grade-ledger.js"],
    "engine7_visualGpsFeel": ["migration candidate: src/visual-polish-7.js", "active: src/gps-system.js"],
    "engine7_1_gpsMapStability": ["src/gps-system.js", "src/radar-compass-system.js", "migration candidate: src/stable-map-region.js"],
    "engine8_runtimeCleanup": ["engine-manifest.json", "docs/engine-history.md"],
    "engine9_unifiedCore": ["src/engine-9-runtime.js", "engine-manifest.json", "docs/engine-9-0-unified-core.md"]
  },
  "runtimeOwners": {
    "coreGameLoop": {
      "owner": "src/main-radar.js",
      "includes": ["player state", "map render", "radar", "bug spawn", "capture mini-game", "base dex", "quest/open/save hooks"],
      "mustNotBeDuplicatedBy": ["src/region-remaster.js", "src/stable-map-region.js", "src/visual-polish-7.js"]
    },
    "gpsExplorerMode": {
      "owner": "src/gps-system.js",
      "includes": ["GPS permission", "watchPosition", "GPS HUD", "north-up movement"],
      "rule": "GPS must not rotate movement by compass heading."
    },
    "compassRadarInfo": {
      "owner": "src/radar-compass-system.js",
      "includes": ["explorer toggle button", "radar compact info", "direction reference"],
      "rule": "Compass is reference only unless a future map-engine explicitly owns rotation."
    },
    "bottomMenu": {
      "owner": "src/menu-remaster.js",
      "includes": ["research note", "quest", "backpack", "BUG HOLE", "settings"],
      "rule": "Do not reintroduce modal-nav-guard or ui-cleanup as separate menu owners."
    },
    "bugHole": {
      "owner": "src/bug-hole-system.js",
      "assistants": ["src/bug-hole-markers.js", "src/return-discovery.js", "src/return-stones.js"],
      "rule": "BUG HOLE must not capture unrelated global menu/back events."
    },
    "backpack": {
      "owner": "src/backpack-system.js",
      "includes": ["inventory UI", "bottom bag menu"]
    },
    "npc": {
      "owner": "src/random-npc.js",
      "assistants": ["src/npc-api-bridge.js", "src/npc-lab.js"],
      "rule": "Bridge is temporary; long-term API belongs in random-npc.js."
    },
    "economy": {
      "owner": "src/economy.js",
      "assistants": ["src/economy-menu.js"]
    },
    "activeItems": {
      "owner": "src/active-items.js",
      "assistants": ["src/active-items-bridge.js"]
    },
    "saveReset": {
      "owner": "src/save-reset-guard.js",
      "rule": "Reset must include GPS/NPC/BUG HOLE/backpack data."
    },
    "legendary": {
      "owner": "src/legendary-event.js",
      "migrationCandidate": "src/legendary-dex-fix.js",
      "rule": "Legendary dex improvements must be merged into a single legendary or dex owner, not reloaded as a fix layer."
    },
    "dexFuture": {
      "ownerStatus": "not yet separated",
      "currentBaseOwner": "src/main-radar.js",
      "migrationCandidates": ["src/dex-grade-ledger.js", "src/dex-category-guard.js", "src/dex-reward.js"],
      "rule": "If enhanced dex returns, create one dex-system.js or merge into main-radar.js openDex."
    },
    "visualFuture": {
      "ownerStatus": "not yet separated",
      "currentBaseOwner": "css/style.css and src/main-radar.js",
      "migrationCandidate": "src/visual-polish-7.js",
      "rule": "Visual polish must be merged into css/style.css or one visual-system.js, not loaded as broad override."
    },
    "engineRuntimeManifest": {
      "owner": "src/engine-9-runtime.js",
      "includes": ["runtime file list", "owner map", "window.CATCHABUGS_ENGINE"],
      "rule": "This file must not mutate gameplay. It is a readable runtime manifest only."
    }
  },
